{
  "generator": "metrics",
  "pgmpy_version": "1.1.2",
  "test_cases": [
    {
      "description": "SHD between true graph (3 edges) and estimated with one extra edge",
      "expected": {
        "shd": 1
      },
      "input": {
        "estimated_edges": [
          [
            "A",
            "B"
          ],
          [
            "B",
            "C"
          ],
          [
            "A",
            "C"
          ],
          [
            "C",
            "D"
          ]
        ],
        "estimated_nodes": [
          "A",
          "B",
          "C",
          "D"
        ],
        "true_edges": [
          [
            "A",
            "B"
          ],
          [
            "B",
            "C"
          ],
          [
            "A",
            "C"
          ]
        ],
        "true_nodes": [
          "A",
          "B",
          "C"
        ]
      },
      "name": "shd_one_extra_edge"
    },
    {
      "description": "SHD between true graph and estimated with one reversed edge (A->B vs B->A)",
      "expected": {
        "shd": 1
      },
