          [
            "B",
            "A"
          ],
          [
            "B",
            "C"
          ]
        ],
        "estimated_nodes": [
          "A",
          "B",
          "C"
        ],
        "true_edges": [
          [
            "A",
            "B"
          ],
          [
            "B",
            "C"
          ]
        ],
        "true_nodes": [
          "A",
          "B",
          "C"
        ]
      },
      "name": "shd_reversal"
    },
    {
      "description": "Adjacency confusion matrix: true has A->C, est has C->D instead",
      "expected": {
        "fn": 1,
        "fp": 1,
        "tn": 2,
        "tp": 2
      },
      "input": {
        "estimated_edges": [
          [
            "A",
            "B"
          ],
          [
            "B",
            "C"
          ],
          [
            "C",
            "D"
          ]
        ],
        "estimated_nodes": [
          "A",
          "B",
